{
  "flavor": "deployment",
  "metadata": {
    "labels": {
      "deliveryType": "MANUAL"
    }
  },
  "kind": "service",
  "disabled": false,
  "version": "0.1",
  "spec": {
    "enable_host_anti_affinity": false,
    "type": "application",
    "restart_policy": "Always",
    "release": {
      "strategy": {
        "type": "RollingUpdate"
      },
      "image": "${blueprint.self.artifacts.capillary-cloud-agent}",
      "image_pull_policy": "Always"
    },
    "runtime": {
      "args": [],
      "command": [],
      "autoscaling": {
        "scaling_on": "CPU",
        "min": 1,
        "max": 1,
        "cpu_threshold": 50
      },
      "ports": {
        "http": {
          "port": 8000,
          "protocol": "tcp"
        }
      },
      "size": {
        "cpu": "300m",
        "memory": "1Gi",
        "cpu_limit": "1000m",
        "memory_limit": "5Gi"
      },
      "health_checks": {
        "port": 8000,
        "timeout": 3,
        "readiness_check_type": "None",
        "liveness_check_type": "None",
        "startup_check_type": "None"
      }
    },
    "env": {
      "LOG_LEVEL": "INFO",
      "OPENAI_API_KEY": "${blueprint.self.secrets.OPENAI_API_KEY}",
      "ANTHROPIC_API_KEY": "${blueprint.self.secrets.ANTHROPIC_API_KEY}",
      "SESSION_STORE_TYPE": "mongo",
      "MONGO_DB_NAME": "aiagents",
      "MONGO_URI": "${mongo.control-plane.out.interfaces.cluster.connection_string}",
      "ENVIRONMENT": "production",
      "AUTH_MODE": "facets",
      "DEFAULT_DOLLAR_LIMIT": "10",
      "ENCRYPTION_KEY": "${blueprint.self.variables.ENCRYPTION_KEY}",
      "SLACK_APP_CLIENT_ID": "${blueprint.self.variables.FACETS_SLACK_APP_CLIENT_ID}",
      "GITHUB_APP_PRIVATE_KEY_BASE64": "${blueprint.self.secrets.PRAXIS_FACETS_GITHUB_APP_PRIVATE_KEY_BASE64_ENCODED}",
      "GITHUB_APP_APP_ID": "${blueprint.self.variables.PRAXIS_FACETS_GITHUB_APP_APP_ID}",
      "GITHUB_APP_CLIENT_ID": "${blueprint.self.variables.PRAXIS_FACETS_GITHUB_APP_CLIENT_ID}",
      "GITHUB_APP_SLUG": "${blueprint.self.variables.PRAXIS_GITHUB_APP_SLUG}",
      "STRIPE_API_KEY": "${blueprint.self.secrets.STRIPE_API_KEY}"
    },
    "cloud_permissions": {
      "aws": {
        "enable_irsa": false,
        "iam_policies": {
          "iam-policies1": {
            "arn": "${iam_policy.assume-role-policy.out.attributes.arn}"
          }
        }
      }
    }
  },
  "uiProps": {}
}